# --- Core ---
DATABASE_URL=sqlite:///./storage/invoices.db
STORAGE_DIR=./storage/uploads
LOW_CONFIDENCE_THRESHOLD=0.75

# --- Groq (structured extraction LLM, free tier) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- OCR & Preprocessing Performance (Local CPU-Only) ---
PDF_DPI=150
OCR_PREFER=rapid # rapid (lightweight ONNX) | paddle (heavy PP-StructureV3)
BYPASS_NATIVE_PDF_OCR=true

# --- Multimodal Vision Extraction Settings (Phase 2) ---
USE_VISION_EXTRACTION=true
VISION_PROVIDER=groq  # groq | gemini
VISION_MODEL=llama-3.2-11b-vision-preview  # llama-3.2-11b-vision-preview / llama-3.2-90b-vision-preview / gemini-1.5-flash
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Sheets export (service account, free) ---
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service_account.json
# Railway/cloud deployments cannot read local credential files. Paste the full
# service account JSON here in Railway's Variables tab.
GOOGLE_SERVICE_ACCOUNT_JSON_CONTENT=
GOOGLE_SHEET_ID=your_google_sheet_id_here
SHEETS_MODE=flat   # flat | normalized

# --- Excel export ---
EXCEL_EXPORT_DIR=./storage/exports

# --- Optional CRM / accounting webhook (e.g. n8n / Zapier / Make) ---
EXPORT_WEBHOOK_URL=

# --- Email ingestion (IMAP) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your_inbox@example.com
IMAP_PASSWORD=your_app_password
IMAP_FOLDER=INBOX
IMAP_MARK_SEEN=true
